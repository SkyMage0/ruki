# Environment
ENVIRONMENT=development
DEBUG=false

# Database (PostgreSQL 15+)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ruki
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ruki
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/ruki

# Redis
REDIS_URL=redis://localhost:6379/0

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Encryption (Fernet key, base64). Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# JWT (admin API)
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Sentry (errors & exceptions)
SENTRY_DSN=

# CORS (comma-separated origins for admin panel)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Rate limits
RATE_LIMIT_CREATE_TASK_PER_HOUR=5
RATE_LIMIT_CREATE_BID_PER_HOUR=20
RATE_LIMIT_SEND_MESSAGE_PER_MINUTE=30
RATE_LIMIT_VERIFICATION_PER_DAY=3
